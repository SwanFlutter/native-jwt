{
    "name": "swanflutter/native-jwt",
    "description": "A standalone, dependency-free JWT library for PHP (HMAC, RSA, ECDSA) with built-in algorithm-confusion and alg=none protection.",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": [
        "jwt",
        "token",
        "auth",
        "hmac",
        "rsa",
        "ecdsa",
        "standalone",
        "firebase"
    ],
    "authors": [
        {
            "name": "SwanFlutter",
            "email": "swan.dev1993@gmail.com"
        }
    ],
    "homepage": "https://github.com/swanflutter/native-jwt",
    "support": {
        "issues": "https://github.com/swanflutter/native-jwt/issues",
        "source": "https://github.com/swanflutter/native-jwt"
    },
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-hash": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "laravel/pint": "^1.17|^2.0"
    },
    "autoload": {
        "psr-4": {
            "SwanFlutter\\NativeJwt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SwanFlutter\\NativeJwt\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
