{
    "name": "swanflutter/native-jwt",
    "description": "A PHP 8.1+ JWT library (HMAC, RSA, ECDSA, EdDSA, RSASSA-PSS) with JWK/JWKS support, PSR-6 cached key sets, and built-in algorithm-confusion and alg=none protection.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "jwt",
        "token",
        "auth",
        "hmac",
        "rsa",
        "ecdsa",
        "eddsa",
        "ed25519",
        "rsa-pss",
        "jwk",
        "jwks",
        "firebase",
        "fcm",
        "standalone"
    ],
    "authors": [
        {
            "name": "SwanFlutter",
            "email": "swan.dev1993@gmail.com"
        }
    ],
    "homepage": "https://github.com/swanflutter/native-jwt",
    "support": {
        "issues": "https://github.com/swanflutter/native-jwt/issues",
        "source": "https://github.com/swanflutter/native-jwt"
    },
    "version": "1.2.0",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-hash": "*"
    },
    "suggest": {
        "ext-sodium": "Required for EdDSA (Ed25519) algorithm support.",
        "ext-gmp": "Required for JWK RSA key parsing (JWK::parseKeySet).",
        "psr/http-client": "Required for CachedKeySet (PSR-18 HTTP client).",
        "psr/http-factory": "Required for CachedKeySet (PSR-17 request factory).",
        "psr/cache": "Required for CachedKeySet (PSR-6 cache pool)."
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "laravel/pint": "^1.17|^2.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/cache": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "SwanFlutter\\NativeJwt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SwanFlutter\\NativeJwt\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "format": "pint"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
